# Groq（危機偵測 Agent + 摘要 Agent）
GROQ_API_KEY=
CRISIS_MODEL=llama-3.1-8b-instant
SUMMARY_MODEL=llama-3.3-70b-versatile

# Gemini（對話 Agent + 分析 Agent）
GEMINI_API_KEY=
CONVERSATION_MODEL=gemini-2.5-flash-lite
ANALYSIS_MODEL=gemini-2.5-flash

# Report v2（預設 deterministic，不會呼叫 provider）
# deterministic：使用保守 deterministic 草稿，不需 provider 呼叫
# provider：明確啟用 Report v2 provider 產生 AI 草稿，需要對應 provider API key
REPORT_V2_PROVIDER_MODE=deterministic
# provider mode 下可選 gemini 或 groq；未設定時預設 gemini
REPORT_V2_PROVIDER=gemini
# 可留空；gemini fallback: REPORT_V2_MODEL -> gemini-2.5-flash
# groq fallback: REPORT_V2_MODEL -> llama-3.3-70b-versatile
REPORT_V2_MODEL=gemini-2.5-flash
# 可留空；若設定，Report v2 provider calls 會優先使用此 key
# 若留空，gemini 使用 GEMINI_API_KEY，groq 使用 GROQ_API_KEY
# 可用於將 report generation quota 與 crisis/summary quota 分離
REPORT_V2_API_KEY=

# Report v2 fallback（選用，預設關閉）
# 僅在 REPORT_V2_PROVIDER_MODE=provider 且 primary provider 發生 provider_api_failure 時才會嘗試
# 不會對 invalid JSON、schema validation、unsafe evidence refs、missing summaries 等情況 fallback
REPORT_V2_FALLBACK_ENABLED=false
REPORT_V2_FALLBACK_PROVIDER=groq
REPORT_V2_FALLBACK_MODEL=llama-3.3-70b-versatile
# 可留空；若設定，fallback provider call 會優先使用此 key
# 若留空，會依序使用 REPORT_V2_API_KEY 或 provider-specific key
REPORT_V2_FALLBACK_API_KEY=

# 其他系統設定
DATABASE_PATH=./cases.db
MAX_CRISIS_INPUT_CHARS=1000
CONVERSATION_WINDOW_SIZE=10
CONVERSATION_MAX_TOKENS=600
MIN_TURNS_FOR_REPORT=3
